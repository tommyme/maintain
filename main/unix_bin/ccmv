#!/usr/bin/env bash
#
# ccmv - Claude Code session 目录迁移助手
#
# 用法:
#   ccmv <项目名> <新路径>
#   ccmv <项目名> <新路径> -s <session目录名>
#
# 示例:
#   ccmv tmux-palette ~/repos
#   ccmv tmux-palette ~/repos/new-name
#   ccmv tmux-palette ~/repos -s -Users-flag-maintain-main-tmux

set -euo pipefail

# ─── 颜色 ───
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'

CLAUDE_PROJECTS_DIR="$HOME/.claude/projects"

usage() {
    echo -e "${BOLD}ccmv${NC} - Claude Code session 目录迁移助手"
    echo ""
    echo -e "${BOLD}用法:${NC}"
    echo "  ccmv <项目名> <新路径>"
    echo "  ccmv <项目名> <新路径> -s <session目录名>"
    echo ""
    echo -e "${BOLD}示例:${NC}"
    echo "  ccmv tmux-palette ~/repos"
    echo "  ccmv tmux-palette ~/repos -s -Users-flag-maintain-main-tmux"
    exit 1
}

# ─── 解析参数 ───
[[ $# -lt 2 ]] && usage

PROJECT_NAME="$1"
RAW_NEW_PATH="$2"
SOURCE_NAME=""

if [[ $# -ge 4 && "$3" == "-s" ]]; then
    SOURCE_NAME="$4"
elif [[ $# -ne 2 ]]; then
    usage
fi

# ─── 转绝对路径（shell 已展开 ~，只需处理相对路径）───
to_abs() {
    local p="$1"
    case "$p" in
        /*) echo "$p" ;;
        *)  echo "$(pwd)/$p" ;;
    esac
}

# 路径 → session 目录名
path_to_session() {
    echo "${1//\//-}"
}

# ─── 计算项目目标绝对路径 ───
NEW_PATH_ABS=$(to_abs "$RAW_NEW_PATH")

if [[ -d "$NEW_PATH_ABS" ]]; then
    PROJECT_DEST="$NEW_PATH_ABS/$PROJECT_NAME"
else
    PROJECT_DEST="$NEW_PATH_ABS"
fi

# ─── 打印 session 文件 ───
print_sessions() {
    local dir="$1"
    find "$dir" -maxdepth 1 -name "*.jsonl" -type f -exec basename {} \; | sort | while read -r f; do
        local sz
        sz=$(du -h "$dir/$f" 2>/dev/null | cut -f1 | tr -d ' ')
        echo -e "      ${CYAN}├─${NC} $f  ${DIM}($sz)${NC}"
    done
}

# ─── 开始 ───
echo ""
echo -e "${BOLD}${CYAN}══════════════════════════════════════════════════${NC}"
echo -e "${BOLD}  ccmv · Claude Code Session 迁移${NC}"
echo -e "${BOLD}${CYAN}══════════════════════════════════════════════════${NC}"
echo ""

# ─── Step 1: 确定源 session 目录 ───
SOURCE_DIR=""

if [[ -n "$SOURCE_NAME" ]]; then
    if [[ -d "$CLAUDE_PROJECTS_DIR/$SOURCE_NAME" ]]; then
        SOURCE_DIR="$SOURCE_NAME"
        echo -e "${BOLD}[1] 📂 源${NC}  ${DIM}(-s 指定)${NC}"
    else
        echo -e "    ${RED}❌ session 目录不存在: $SOURCE_NAME${NC}"
        exit 1
    fi
else
    echo -e "${BOLD}[1] 🔍 搜索源${NC}  ${DIM}(关键词: \"$PROJECT_NAME\")${NC}"
    echo ""

    mapfile -t MATCHES < <(
        ls -1 "$CLAUDE_PROJECTS_DIR" 2>/dev/null | grep -i "$PROJECT_NAME" || true
    )

    if [[ ${#MATCHES[@]} -eq 0 ]]; then
        echo -e "    ${RED}❌ 未匹配到 \"$PROJECT_NAME\"${NC}"
        echo ""

        if command -v fzf &>/dev/null; then
            echo -e "    ${DIM}正在打开 fzf，请选择源 session 目录...${NC}"
            echo ""
            SOURCE_DIR=$(ls -1 "$CLAUDE_PROJECTS_DIR" 2>/dev/null | fzf \
                --height=40% \
                --reverse \
                --prompt="选择 session 目录 > " \
                --header="↑↓ 移动  Enter 选择  Esc 取消" \
                --query="$PROJECT_NAME" \
            ) || true

            if [[ -z "$SOURCE_DIR" ]]; then
                echo -e "    ${YELLOW}已取消${NC}"
                exit 0
            fi
        else
            echo -e "    ${YELLOW}安装 fzf 可交互选择: ${NC}${BOLD}brew install fzf${NC}"
            echo -e "    ${DIM}或 ${NC}ls ~/.claude/projects/${DIM} 查看后加 ${NC}-s <目录名>${DIM} 指定${NC}"
            exit 1
        fi
    elif [[ ${#MATCHES[@]} -eq 1 ]]; then
        SOURCE_DIR="${MATCHES[0]}"
        echo -e "    ${GREEN}✅${NC} $SOURCE_DIR"
    else
        for i in "${!MATCHES[@]}"; do
            dir="${MATCHES[$i]}"
            cnt=$(find "$CLAUDE_PROJECTS_DIR/$dir" -maxdepth 1 -name "*.jsonl" -type f 2>/dev/null | wc -l | tr -d ' ')
            echo -e "    ${GREEN}[$((i+1))]${NC} $dir  ${DIM}($cnt sessions)${NC}"
        done
        echo ""
        read -rp "    选择 [1-${#MATCHES[@]}]: " choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#MATCHES[@]} )); then
            SOURCE_DIR="${MATCHES[$((choice-1))]}"
        else
            echo -e "    ${RED}无效${NC}"; exit 1
        fi
    fi
fi

SOURCE_FULL="$CLAUDE_PROJECTS_DIR/$SOURCE_DIR"
SRC_CNT=$(find "$SOURCE_FULL" -maxdepth 1 -name "*.jsonl" -type f 2>/dev/null | wc -l | tr -d ' ')

echo ""
echo -e "    ${BOLD}$SOURCE_DIR${NC}  ${DIM}($SRC_CNT sessions)${NC}"
print_sessions "$SOURCE_FULL"
echo ""

# ─── Step 2: 目标 ───
TARGET_DIR=$(path_to_session "$PROJECT_DEST")
TARGET_FULL="$CLAUDE_PROJECTS_DIR/$TARGET_DIR"

echo -e "${BOLD}[2] 📁 目标${NC}"
echo -e "    项目路径: ${BOLD}$PROJECT_DEST${NC}"
echo -e "    Session:  ${BOLD}$TARGET_DIR${NC}"

MERGE=false
if [[ "$SOURCE_FULL" == "$TARGET_FULL" ]]; then
    echo ""
    echo -e "    ${YELLOW}源和目标相同，无需迁移。${NC}"
    exit 0
elif [[ -d "$TARGET_FULL" ]]; then
    ext=$(find "$TARGET_FULL" -maxdepth 1 -name "*.jsonl" -type f 2>/dev/null | wc -l | tr -d ' ')
    echo -e "    ${YELLOW}⚠️  session 目录已存在 ($ext sessions)${NC}"
    MERGE=true
else
    echo -e "    ${CYAN}🆕 session 目录将新建${NC}"
fi

echo ""

# ─── Step 3: 查找项目当前路径 ───
PROJECT_SRC=""
for candidate in "$(pwd)/$PROJECT_NAME" "$HOME/$PROJECT_NAME"; do
    if [[ -d "$candidate" ]]; then
        PROJECT_SRC=$(cd "$candidate" && pwd -P)
        break
    fi
done

# ─── Step 4: 打印命令并确认执行 ───
echo -e "${BOLD}[3] 🚀 将执行以下命令:${NC}"
echo ""

CMDS=()

# 命令 1: session 迁移
if [[ "$MERGE" == true ]]; then
    CMDS+=("cp -rn \"$SOURCE_FULL/\"* \"$TARGET_FULL/\"")
    CMDS+=("rm -rf \"$SOURCE_FULL\"")
    echo -e "    ${DIM}# 迁移 session (合并)${NC}"
    for c in "${CMDS[@]}"; do echo -e "    ${BOLD}$c${NC}"; done
else
    CMDS+=("mv \"$SOURCE_FULL\" \"$TARGET_FULL\"")
    echo -e "    ${DIM}# 迁移 session${NC}"
    echo -e "    ${BOLD}${CMDS[-1]}${NC}"
fi

echo ""

# 命令 2: 移动项目目录
if [[ -n "$PROJECT_SRC" && "$PROJECT_SRC" != "$PROJECT_DEST" ]]; then
    CMDS+=("mv \"$PROJECT_SRC\" \"$PROJECT_DEST\"")
    echo -e "    ${DIM}# 移动项目目录${NC}"
    echo -e "    ${BOLD}${CMDS[-1]}${NC}"
elif [[ -n "$PROJECT_SRC" && "$PROJECT_SRC" == "$PROJECT_DEST" ]]; then
    echo -e "    ${DIM}# 项目目录已在目标位置，无需移动${NC}"
else
    echo -e "    ${DIM}# 移动项目目录 (未找到源，请手动执行)${NC}"
    echo -e "    ${YELLOW}mv /path/to/$PROJECT_NAME \"$PROJECT_DEST\"${NC}"
fi

echo ""
read -rp "    确认执行? [y/N]: " yn
case "$yn" in
    [yY]|[yY][eE][sS])
        echo ""
        for cmd in "${CMDS[@]}"; do
            echo -e "    ${DIM}\$ $cmd${NC}"
            eval "$cmd"
        done
        echo ""
        echo -e "    ${GREEN}✅ 迁移完成${NC}"
        ;;
    *)
        echo -e "    ${YELLOW}已取消${NC}"
        ;;
esac

echo ""

